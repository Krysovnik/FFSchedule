<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="BackgroundColor">#121212</Color>
    <Color x:Key="ForegroundColor">#FFFAFA</Color>
    <!--Цвета - текста-->
    <Color x:Key="MainTextColor">#E0E0E0</Color>
    <Color x:Key="SecTextColor">#AAAAAA</Color>
    <!--Цвет - обводка-->
    <Color x:Key="OutlinesColor">#333333</Color>
    <!--Цвет - textBox-->
    <Color x:Key="BackgroundTextBoxColor">#1C1C1C</Color>
    <!--Цвета - акцентов (кнопки, навигация, предупреждение, экстренные действия)-->
    <Color x:Key="RedColor">#FF5252</Color>
    <Color x:Key="BlueColor">#42A5F5</Color>
    <Color x:Key="OrangeColor">#FFB74D</Color>
    <Color x:Key="OrangeColorLight">#FFC85D</Color>
    <!--Цвета - Статус-->
    <Color x:Key="SuccessColor">#66BB6A</Color>
    <Color x:Key="AttentionColor">#FFD54F</Color>
    <Color x:Key="ErrorColor">#EF5350</Color>
    <!--Кисти-->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="ForegroundBrush" Color="{StaticResource ForegroundColor}"/>
    <SolidColorBrush x:Key="OutlinesBrush" Color="{StaticResource OutlinesColor}"/>
    <SolidColorBrush x:Key="BackgroundTextBoxBrush" Color="{StaticResource BackgroundTextBoxColor}"/>
    <SolidColorBrush x:Key="OrangeBrush" Color="{StaticResource OrangeColor}"/>
    <SolidColorBrush x:Key="OrangeBrushLight" Color="{StaticResource OrangeColorLight}"/>

</ResourceDictionary>