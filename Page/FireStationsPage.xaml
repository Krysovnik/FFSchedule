<Page x:Class="FFSchedule.Page.FireStationsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FFSchedule.Page"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="FireStationsPage">

    <StackPanel Margin="10">
        <TextBlock Text="Список пожарных частей" 
                   FontWeight="Bold" 
                   FontSize="14" 
                   Foreground="{DynamicResource MainTextColorBrush}"
                   Margin="5,0,0,10"/>

        <ListBox x:Name="FireStationsListBox" 
         Style="{StaticResource ModernListBoxStyle}"
         Height="300" 
         Margin="0,0,0,10" 
         SelectionMode="Single"
         SelectionChanged="FireStationsListBox_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="2,0">
                        <TextBlock Text="{Binding Name}" 
                           FontWeight="SemiBold" 
                           FontSize="13"
                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"/>

                        <TextBlock Text="{Binding Address}" 
                           FontSize="11" 
                           Margin="0,3,0,0"
                           Opacity="0.7"
                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <TextBlock Text="Информация о пожарной части" 
                   FontWeight="Bold" 
                   Foreground="{DynamicResource MainTextColorBrush}"
                   FontSize="14" 
                   Margin="5,10,0,5"/>

        <Border x:Name="FireStationInfoPanel" 
        Background="{DynamicResource BackgroundTextBoxBrush}" 
        BorderBrush="{DynamicResource OutlinesBrush}"
        BorderThickness="1"
        Padding="15" 
        CornerRadius="8" 
        Visibility="Collapsed"
        Margin="0,0,0,10">
            <StackPanel>
                <TextBlock x:Name="FireStationName" 
                   FontWeight="Bold" 
                   FontSize="15" 
                   Foreground="{DynamicResource OrangeBrush}"
                   Margin="0,0,0,12"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="Адрес: " 
                       FontWeight="SemiBold" 
                       FontSize="12"
                       Foreground="{DynamicResource MainTextColorBrush}"/>
                    <TextBlock x:Name="FireStationAddress" 
                       FontSize="12"
                       Foreground="{DynamicResource SecTextColorBrush}"
                       TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="Район: " 
                       FontWeight="SemiBold" 
                       FontSize="12"
                       Foreground="{DynamicResource MainTextColorBrush}"/>
                    <TextBlock x:Name="FireStationDistrict" 
                       FontSize="12"
                       Foreground="{DynamicResource SecTextColorBrush}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="Тип: " 
                       FontWeight="SemiBold" 
                       FontSize="12"
                       Foreground="{DynamicResource MainTextColorBrush}"/>
                    <TextBlock x:Name="FireStationType" 
                       FontSize="12"
                       Foreground="{DynamicResource SecTextColorBrush}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="Телефон: " 
                       FontWeight="SemiBold" 
                       FontSize="12"
                       Foreground="{DynamicResource MainTextColorBrush}"/>
                    <TextBlock x:Name="FireStationPhone" 
                       FontSize="12"
                       Foreground="{DynamicResource SecTextColorBrush}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <TextBlock x:Name="NoSelectionText" 
           Text="Выберите пожарную часть из списка" 
           Foreground="{DynamicResource SecTextColorBrush}"
           FontSize="12"
           FontStyle="Italic" 
           Margin="5,15,0,0"/>
    </StackPanel>
</Page>
