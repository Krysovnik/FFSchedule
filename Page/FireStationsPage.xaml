<Page x:Class="FFSchedule.Page.FireStationsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FFSchedule.Page"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="FireStationsPage">

    <StackPanel Margin="10">
        <TextBlock Text="Список пожарных частей" 
                   FontWeight="Bold" 
                   FontSize="14" 
                   Margin="0,0,0,10"/>

        <ListBox x:Name="FireStationsListBox" 
                 Height="300" 
                 Margin="0,0,0,10" 
                 Background="White" 
                 BorderBrush="Gray" 
                 BorderThickness="1"
                 SelectionMode="Single"
                 SelectionChanged="FireStationsListBox_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Gray" 
                            BorderThickness="0,0,0,1" 
                            Padding="5" 
                            Margin="0,2">
                        <StackPanel>
                            <TextBlock Text="{Binding Name}" 
                                       FontWeight="Bold" 
                                       Foreground="Black"/>
                            <TextBlock Text="{Binding Address}" 
                                       Foreground="Gray" 
                                       FontSize="11"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <TextBlock Text="Информация о пожарной части" 
                   FontWeight="Bold" 
                   FontSize="14" 
                   Margin="0,10,0,5"/>

        <Border x:Name="FireStationInfoPanel" 
                Background="White" 
                Padding="10" 
                CornerRadius="5" 
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock x:Name="FireStationName" 
                           FontWeight="Bold" 
                           FontSize="13" 
                           Margin="0,0,0,5"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBlock Text="Адрес: " FontWeight="SemiBold"/>
                    <TextBlock x:Name="FireStationAddress"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBlock Text="Район: " FontWeight="SemiBold"/>
                    <TextBlock x:Name="FireStationDistrict"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBlock Text="Тип: " FontWeight="SemiBold"/>
                    <TextBlock x:Name="FireStationType"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBlock Text="Телефон: " FontWeight="SemiBold"/>
                    <TextBlock x:Name="FireStationPhone"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <TextBlock x:Name="NoSelectionText" 
                   Text="Выберите пожарную часть из списка" 
                   FontStyle="Italic" 
                   Foreground="Gray" 
                   Margin="0,10,0,0"/>
    </StackPanel>
</Page>
