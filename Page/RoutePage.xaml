<Page x:Class="FFSchedule.Page.RoutePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FFSchedule.Page" xmlns:controls="clr-namespace:FFSchedule.Controls"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RoutePage">

    <StackPanel Margin="10">
        <ComboBox x:Name="RankComboBox" 
                  DisplayMemberPath="RNumber" 
                  Width="115" 
                  HorizontalAlignment="Left" 
                  Margin="0,20,0,20"/>
        <Button Content="Построить маршрут" 
                x:Name="RouteButton"
                Click="BuildRoute_Click" 
                HorizontalAlignment="Left" 
                Margin="0,20,0,0"/>
        <TextBlock x:Name="BlockDistance" 
                   Text="Расстояние: —" 
                   Margin="0,10,0,0" 
                   HorizontalAlignment="Left"/>
        <TextBlock x:Name="BlockDuration" 
                   Text="Время: —" 
                   Margin="0,10,0,0" 
                   HorizontalAlignment="Left" />
    </StackPanel>
</Page>
