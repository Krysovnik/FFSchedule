<Page x:Class="FFSchedule.Page.RoutePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FFSchedule.Page" xmlns:controls="clr-namespace:FFSchedule.Controls"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RoutePage">

    <StackPanel Margin="10">
        <StackPanel Orientation="Horizontal">
            <Button Content="Построить" 
                x:Name="RouteButton"
                Style="{StaticResource OutlineActionButtonStyle}"
                Click="BuildRoute_Click" 
                HorizontalAlignment="Left" 
                Margin="0,20,10,20"/>
            <ComboBox x:Name="RankComboBox" 
                DisplayMemberPath="RNumber" 
                Width="80" 
                Margin="0,20,0,20"/>
        </StackPanel>
        <ListBox x:Name="StationsListBox"
             Visibility="Collapsed"
             HorizontalAlignment="Left" 
             Width="380" 
             BorderThickness="0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="0,5">
                        <TextBlock Text="{Binding StationName}" FontWeight="SemiBold" FontSize="14"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="{Binding DistanceText}" Margin="0,0,15,0" Foreground="#444"/>
                            <TextBlock Text="{Binding DurationText}" Foreground="#444"/>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </StackPanel>
</Page>
