<Page x:Class="FFSchedule.Page.RoutePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FFSchedule.Page"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RoutePage">

    <StackPanel Margin="10">
        <StackPanel Orientation="Horizontal" Margin="0,10,0,10">
            <TextBox x:Name="SearchTextBox" 
             Background="White" 
             Height="25" 
             Width="300" 
             BorderThickness="1"
             Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <Button Content="🔍 Поиск" 
            x:Name="SearchButton" 
            Click="SearchButton_Click" 
            Width="80" 
            Margin="10,0,0,0"/>
        </StackPanel>

        <ListBox x:Name="SearchResultsLb" 
         Visibility="Collapsed" 
         MaxHeight="200" 
         Margin="5" 
         Background="White"
         MouseDoubleClick="SearchResultsLb_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding DisplayName}" 
                       ToolTip="{Binding Address}"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <Button Content="Построить маршрут" 
                x:Name="RouteButton"
                Click="BuildRoute_Click" 
                HorizontalAlignment="Left" 
                Margin="0,20,0,20"/>
        <TextBlock x:Name="BlockDistance" 
                   Text="Расстояние: —" 
                   Margin="0,10,0,0" 
                   HorizontalAlignment="Left"/>
        <TextBlock x:Name="BlockDuration" 
                   Text="Время: —" 
                   Margin="0,10,0,0" 
                   HorizontalAlignment="Left" />
    </StackPanel>
</Page>
