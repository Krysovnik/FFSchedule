<Page x:Class="FFSchedule.Page.RoutePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FFSchedule.Page" xmlns:controls="clr-namespace:FFSchedule.Controls"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RoutePage">

    <StackPanel Margin="10">
        <StackPanel Orientation="Horizontal">
            <Button Content="Построить" 
                x:Name="RouteButton"
                Style="{StaticResource OutlineActionButtonStyle}"
                Click="BuildRoute_Click" 
                HorizontalAlignment="Left" 
                Margin="5,20,10,20"/>

            <Button Content="+" 
                x:Name="AddRouteButton"
                Style="{StaticResource OutlineActionButtonStyle}"
                Click="AddRouteButton_Click" 
                Visibility="Collapsed" 
                HorizontalAlignment="Left" 
                Margin="0,20,10,20"/>
            
            <ComboBox x:Name="RankComboBox" 
                Style="{StaticResource ModernComboBoxStyle}"
                DisplayMemberPath="RNumber" 
                Width="80" 
                Margin="0,20,0,20"/>
            
        </StackPanel>
        <ListBox x:Name="StationsListBox"
         Style="{StaticResource ModernListBoxStyle}"
         Visibility="Collapsed"
         HorizontalAlignment="Left" 
         Width="380" 
         MaxHeight="250" 
         ScrollViewer.VerticalScrollBarVisibility="Auto" 
         ScrollViewer.CanContentScroll="True"
         Margin="0,0,0,10">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="2,0">
                        <TextBlock Text="{Binding StationName}" 
                           FontWeight="SemiBold" 
                           FontSize="14"
                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"/>

                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock x:Name="DistanceTxt" 
                               Text="{Binding DistanceText}" 
                               Margin="0,0,15,0" 
                               FontSize="12"
                               Foreground="{DynamicResource SecTextColorBrush}"/>

                            <TextBlock x:Name="DurationTxt" 
                               Text="{Binding DurationText}" 
                               FontSize="12"
                               Foreground="{DynamicResource SecTextColorBrush}"/>
                        </StackPanel>
                    </StackPanel>

                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                            <Setter TargetName="DistanceTxt" Property="Foreground" Value="White"/>
                            <Setter TargetName="DurationTxt" Property="Foreground" Value="White"/>
                            <Setter TargetName="DistanceTxt" Property="Opacity" Value="0.8"/>
                            <Setter TargetName="DurationTxt" Property="Opacity" Value="0.8"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True">
                            <Setter TargetName="DistanceTxt" Property="Foreground" Value="White"/>
                            <Setter TargetName="DurationTxt" Property="Foreground" Value="White"/>
                            <Setter TargetName="DistanceTxt" Property="Opacity" Value="0.8"/>
                            <Setter TargetName="DurationTxt" Property="Opacity" Value="0.8"/>
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </StackPanel>
</Page>
