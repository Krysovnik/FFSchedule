<Page x:Class="FFSchedule.Page.WordPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FFSchedule.Page"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="WordPage">

    <Grid>
        <StackPanel Margin="10">
            <Button Content="Добавить пожарную часть"
                    Click="AddDepartment_Click"
                    Margin="5,10,0,0"
                    Style="{StaticResource OutlineActionButtonStyle}" 
                    HorizontalAlignment="Left"
                    Width="200"/>

            <Button Content="Удалить пожарную часть"
                    Click="DeleteDepartment_Click"
                    Margin="5,10,0,0"
                    Style="{StaticResource OutlineActionButtonStyle}"
                    HorizontalAlignment="Left"
                    Width="200"/>

            <Button Content="Создать таблицу в Word" 
                    Click="GenerateWordTable_Click"
                    Style="{StaticResource OutlineActionButtonStyle}"
                    Margin="5,20,0,0" 
                    HorizontalAlignment="Left"
                    Width="200"/>
            
        </StackPanel>
    </Grid>
</Page>
