<Page x:Class="FFSchedule.Page.SearchPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FFSchedule.Page"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SearchPage">

    <StackPanel Margin="10">
        <StackPanel Orientation="Horizontal" Margin="0,10,0,10">
            <TextBox x:Name="SearchTextBox" 
                     Background="White" 
                     Height="25" 
                     Width="300" 
                     BorderThickness="1"
                     Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <Button Content="🔍 Поиск" 
                    x:Name="SearchButton" 
                    Click="SearchButton_Click" 
                    Width="80" 
                    Margin="10,0,0,0"/>
        </StackPanel>

        <ListBox x:Name="SearchResultsLb" 
                 Visibility="Collapsed" 
                 MaxHeight="200" 
                 Margin="5" 
                 Background="White"
                 MouseDoubleClick="SearchResultsLb_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding DisplayName}" 
                               ToolTip="{Binding Address}"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <TextBlock Text="Выберите пожарную часть на карте" 
                   FontStyle="Italic" 
                   Foreground="Gray" 
                   Margin="0,20,0,10" 
                   HorizontalAlignment="Left" />

        <Button Content="Создать таблицу в Word" 
                Click="GenerateWordTable_Click" 
                Margin="0,20,0,0" 
                HorizontalAlignment="Left" />
    </StackPanel>
</Page>
