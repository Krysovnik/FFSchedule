<Window x:Class="FFSchedule.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FFSchedule"
        xmlns:controls="clr-namespace:FFSchedule.Controls"
        xmlns:mapsui="clr-namespace:Mapsui.UI.Wpf;assembly=Mapsui.UI.Wpf"
        mc:Ignorable="d"
        Title="MainWindow" Height="720" Width="1280" Background="{DynamicResource BackgroundBrush}">
    <DockPanel LastChildFill="True">
        <Menu DockPanel.Dock="Top" Background="#F0F0F0">
            <MenuItem Header="Файл">
                <MenuItem Header="Новый проект"/>
                <MenuItem Header="Открыть проект"/>
                <MenuItem Header="Сохранить проект"/>
                <Separator/>
                <MenuItem Header="Выход"/>
            </MenuItem>
            <MenuItem Header="Правка">
                <MenuItem Header="Отменить"/>
                <MenuItem Header="Повторить"/>
            </MenuItem>
            <MenuItem Header="Карта">
                <MenuItem Header="Добавить маркер"/>
                <MenuItem Header="Удалить маркер"/>
                <MenuItem Header="Обновить карту" Click="RefreshMap_Click"/>
            </MenuItem>

            <MenuItem Header="Вид">
                <MenuItem Header="Заливка полигонов" IsCheckable="True" IsChecked="True" Click="TogglePolygonFill_Click"/>

                <Separator/>

                <MenuItem Header="Толщина границы">
                    <MenuItem Header="Тонкая" Click="BorderWidth_Thin_Click"/>
                    <MenuItem Header="Средняя" Click="BorderWidth_Medium_Click"/>
                    <MenuItem Header="Толстая" Click="BorderWidth_Thick_Click"/>
                </MenuItem>
            </MenuItem>


            <MenuItem Header="Справка">
                <MenuItem Header="О программе"/>
            </MenuItem>
        </Menu>

        <ToolBar DockPanel.Dock="Top" Height="35" Background="{DynamicResource BackgroundBrush}">
            <Button Content="➕" Click="ButtonAddFireStation_Click" ToolTip="Добавить точку" Foreground="{DynamicResource ForegroundBrush}"/>
            <Button Content="✏️" Click="ButtonRedFireStation_Click" ToolTip="Редактировать" Foreground="{DynamicResource ForegroundBrush}"/>
            <Button Content="🗑️" Click="ButtonDelFireStation_Click" ToolTip="Удалить" Foreground="{DynamicResource ForegroundBrush}"/>
            <Separator/>
            <Button Content="📁" ToolTip="Загрузить карту" Foreground="{DynamicResource ForegroundBrush}"/>
            <Button Content="💾" ToolTip="Сохранить" Foreground="{DynamicResource ForegroundBrush}"/>
            <Separator/>
            <Button x:Name="FireStationsToggleButton" 
                    Content="⬤" 
                    Width="22"
                    ToolTip="Скрыть пожарные части" 
                    Foreground="{DynamicResource ForegroundBrush}"
                    Click="FireStationsToggleButton_Click"/>
            <Button x:Name="VillageCouncilsToggleButton" 
                    Content="📖" 
                    ToolTip="Скрыть сельсоветы" 
                    Foreground="{DynamicResource ForegroundBrush}"
                    Click="VillageCouncilsToggleButton_Click" Width="22"/>
            <controls:ThemeToggleButton/>
        </ToolBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.6*" MinWidth="200"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="SidePanel" Background="{DynamicResource OutlinesBrush}">
                    <StackPanel Orientation="Horizontal" Margin="20,10,20,10">
                        <TextBox 
                            x:Name="SearchTextBox"
                            Background="{DynamicResource OutlinesBrush}" 
                            Height="20"
                            Width="300"
                            BorderThickness="1">
                        </TextBox>
                        <Button Content="🔍 Поиск" x:Name="SearchButton" Click="SearchButton_Click" Width="80"/>
                    </StackPanel>
                    <ListBox x:Name="SearchResultsLb" 
                        Visibility="Collapsed"
                        MouseDoubleClick="SearchResultsLb_MouseDoubleClick"
                        MaxHeight="200" 
                        Margin="5">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ShortDisplayName}" 
                                    ToolTip="{Binding DisplayName}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock Text="Информация о пожарной части" 
                        FontWeight="Bold" FontSize="14" 
                        Margin="20,0,0,10" 
                        Foreground="{DynamicResource ForegroundBrush}"/>
                    <Border x:Name="FireStationInfoPanel" 
                        Background="{DynamicResource BackgroundBrush}"
                        Padding="10"
                        CornerRadius="5"
                        Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock x:Name="FireStationName" 
                                FontWeight="Bold" 
                                FontSize="13" 
                                TextWrapping="Wrap"
                                Margin="0,0,0,5"
                                Foreground="{DynamicResource ForegroundBrush}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="Адрес: " 
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource ForegroundBrush}"/>
                                <TextBlock x:Name="FireStationAddress" 
                                    TextWrapping="Wrap"
                                    Foreground="{DynamicResource ForegroundBrush}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="Район: " 
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource ForegroundBrush}"/>
                                <TextBlock x:Name="FireStationDistrict" 
                                    Foreground="{DynamicResource ForegroundBrush}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="Тип: " 
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource ForegroundBrush}"/>
                                <TextBlock x:Name="FireStationType" 
                                    Foreground="{DynamicResource ForegroundBrush}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="Телефон: " 
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource ForegroundBrush}"/>
                                <TextBlock x:Name="FireStationPhone" 
                                    Foreground="{DynamicResource ForegroundBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock x:Name="NoSelectionText" 
                        Text="Выберите пожарную часть на карте" 
                        FontStyle="Italic"
                        Foreground="{DynamicResource ForegroundBrush}"
                        Margin="20,0,0,10"/>

                    <TextBlock Text="Список пожарных частей" 
                        FontWeight="Bold" FontSize="14" 
                        Margin="20,0,0,10" 
                        Foreground="{DynamicResource ForegroundBrush}"/>

                    <ListBox x:Name="FireStationsListBox"
                        Height="300"
                        Margin="20,0,10,10"
                        Background="{DynamicResource BackgroundBrush}"
                        BorderBrush="{DynamicResource ForegroundBrush}"
                        BorderThickness="1"
                        SelectionMode="Single" SelectionChanged="FireStationsListBox_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource ForegroundBrush}" 
                                    BorderThickness="0,0,0,1" 
                                    Padding="5"
                                    Margin="0,2">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" 
                                            FontWeight="Bold" 
                                            Foreground="{DynamicResource ForegroundBrush}"
                                            TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding Address}" 
                                            Foreground="{DynamicResource ForegroundBrush}"
                                            FontSize="11"
                                            TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </ScrollViewer>

            <GridSplitter Grid.Column="1" 
                  Width="2" 
                  HorizontalAlignment="Stretch" 
                  Background="Gray"/>

            <Grid Grid.Column="2">
                <mapsui:MapControl x:Name="MapControl"/>
                <Canvas x:Name="IconCanvas" IsHitTestVisible="False"/>
                <StackPanel VerticalAlignment="Top" HorizontalAlignment="Right" Margin="10,10,0,10">
                    <Button Content="+" Click="ZoomIn_Click" Style="{StaticResource ZoomButtonStyle}"/>
                    <Button Content="-" Click="ZoomOut_Click" Style="{StaticResource ZoomButtonStyle}" Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
