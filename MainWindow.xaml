<Window x:Class="FFSchedule.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FFSchedule"
        xmlns:controls="clr-namespace:FFSchedule.Controls"
        xmlns:mapsui="clr-namespace:Mapsui.UI.Wpf;assembly=Mapsui.UI.Wpf"
        mc:Ignorable="d"
        Title="MainWindow" Height="720" Width="1280" Background="{DynamicResource BackgroundBrush}">
    <DockPanel LastChildFill="True">
        <Menu DockPanel.Dock="Top" Background="#F0F0F0">
            <MenuItem Header="Файл">
                <MenuItem Header="Новый проект"/>
                <MenuItem Header="Открыть проект"/>
                <MenuItem Header="Сохранить проект"/>
                <Separator/>
                <MenuItem Header="Выход"/>
            </MenuItem>
            <MenuItem Header="Правка">
                <MenuItem Header="Отменить"/>
                <MenuItem Header="Повторить"/>
            </MenuItem>
            <MenuItem Header="Карта">
                <MenuItem Header="Добавить маркер"/>
                <MenuItem Header="Удалить маркер"/>
                <MenuItem Header="Обновить карту" Click="RefreshMap_Click"/>
            </MenuItem>

            <MenuItem Header="Вид">
                <MenuItem Header="Заливка полигонов" IsCheckable="True" IsChecked="True" Click="TogglePolygonFill_Click"/>
                <MenuItem Header="Скрыть сельсоветы" IsCheckable="True" Click="VillageCouncilsToggleButton_Click"/>
                <MenuItem Header="Скрыть пожарные части" IsCheckable="True" Click="FireStationsToggleButton_Click"/>

                <Separator/>

                <MenuItem Header="Толщина границы">
                    <MenuItem Header="Тонкая" Click="BorderWidth_Thin_Click"/>
                    <MenuItem Header="Средняя" Click="BorderWidth_Medium_Click"/>
                    <MenuItem Header="Толстая" Click="BorderWidth_Thick_Click"/>
                </MenuItem>
            </MenuItem>


            <MenuItem Header="Справка">
                <MenuItem Header="О программе"/>
            </MenuItem>
        </Menu>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="0.6*" MinWidth="200"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel DockPanel.Dock="Left" Width="50" Background="{DynamicResource BackgroundBrush}" Orientation="Vertical">
                <Button Content="🗺️" FontSize="25" Style="{StaticResource TransparentTextButtonStyle}" Height="50" Click="NavigateToSearch"/>
                <TextBlock Text="Поиск" HorizontalAlignment="Center"/>
                <Button Content="🚒" FontSize="25" Style="{StaticResource TransparentTextButtonStyle}" Height="50" Click="NavigateToFireStations"/>
                <TextBlock Text="ПЧ" HorizontalAlignment="Center"/>
                <Button Content="🛣️" FontSize="25" Style="{StaticResource TransparentTextButtonStyle}" Height="50" Click="NavigateToRoute"/>
                <TextBlock Text="Маршрут" HorizontalAlignment="Center"/>
            </StackPanel>

            <Grid Grid.Column="1" Background="{DynamicResource OutlinesBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <controls:SearchBox x:Name="GlobalSearchBox" 
                            Panel.ZIndex="1"
                            ResultSelected="OnGlobalResultSelected" 
                            Margin="10" 
                            HorizontalAlignment="Stretch" 
                            VerticalAlignment="Top"/>
                        <Button Margin="0,22,0,0"
                            Width="25" Height="25"
                            VerticalAlignment="Top"
                            Click="ClearSearchAndRoute_Click"
                            ToolTip="Очистить поиск и маршрут"
                            Background="White"
                            BorderBrush="#DDD">
                            <Button.Resources>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="CornerRadius" Value="15"/>
                                </Style>
                            </Button.Resources>
                            <Path Data="M0,0 L10,10 M0,10 L10,0" 
                                Stroke="Red" 
                                StrokeThickness="2" 
                                HorizontalAlignment="Center" 
                                VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                    <Frame x:Name="SideFrame" 
                        Grid.Row="0"
                        Panel.ZIndex="0"
                        NavigationUIVisibility="Hidden" 
                        Background="{DynamicResource OutlinesBrush}" 
                        VerticalContentAlignment="Stretch" 
                        HorizontalContentAlignment="Stretch"/>
                </StackPanel>
            </Grid>

            <GridSplitter Grid.Column="2" 
                  Width="2" 
                  HorizontalAlignment="Stretch" 
                  Background="Gray"/>

            <Grid Grid.Column="3">
                <mapsui:MapControl x:Name="MapControl"/>
                <Control x:Name="LoadingIndicator"
                    Style="{StaticResource BusyAnimationStyle}"
                    Visibility="Collapsed"
                    Width="100"
                    Height="100"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>
                <Canvas x:Name="IconCanvas" IsHitTestVisible="False"/>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
