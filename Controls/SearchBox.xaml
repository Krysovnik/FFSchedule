<UserControl x:Class="FFSchedule.Controls.SearchBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FFSchedule.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="250" d:DesignWidth="400">
    <StackPanel Orientation="Vertical">
        <StackPanel Orientation="Vertical" Margin="0,10,0,0">
            <TextBox x:Name="SearchTextBox"
                     Background="White" Height="25" Width="400"
                     Text="{Binding SearchQuery, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     TextChanged="SearchTextBox_TextChanged"/>
        </StackPanel>
        <Grid>
            <ListBox x:Name="SearchResultsLb"
                     Visibility="Collapsed"
                     MaxHeight="200"
                     Width="400"
                     Background="White"
                     MouseDoubleClick="SearchResultsLb_MouseDoubleClick">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding ShortDisplayName}"
                        ToolTip="{Binding DisplayName}"
                        TextTrimming="CharacterEllipsis"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <local:UserControl1 x:Name="LoadingIndicator" 
                   Visibility="Collapsed" 
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Center" 
                   Height="60" Width="60" />

            <TextBlock x:Name="NoResultsText" 
                   Text="Ничего не найдено" 
                   Visibility="Collapsed" 
                   HorizontalAlignment="Center" 
                   Foreground="Gray" 
                   FontStyle="Italic"/>

            <TextBlock x:Name="ErrorText" 
                   Visibility="Collapsed" 
                   HorizontalAlignment="Center" 
                   Foreground="IndianRed" 
                   TextWrapping="Wrap" RenderTransformOrigin="0.5,0.5"/>
        </Grid>
    </StackPanel>
</UserControl>
