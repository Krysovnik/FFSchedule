<Window x:Class="FFSchedule.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FFSchedule"
        xmlns:controls="clr-namespace:FFSchedule.Controls"
        mc:Ignorable="d"
        Title="Авторизация" Height="450" Width="400" Background="{DynamicResource BackgroundBrush}" ResizeMode="NoResize">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="251*"/>
            <ColumnDefinition Width="149*"/>
        </Grid.ColumnDefinitions>
        <Grid Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Border Style="{StaticResource CircleLogoStyle}" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,20,0,0">
                    <Image Style="{StaticResource CircularImageStyle}" Margin="10,6,6,10" 
                   Source="/Images/fire.png"/>
                </Border>
                <controls:ThemeToggleButton  HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10"/>
                <TextBlock VerticalAlignment="Top" 
                    HorizontalAlignment="Center" 
                    Margin="0,125,0,0" 
                    Foreground="{DynamicResource ForegroundBrush}"
                    Text="Авторизация"
                    FontFamily="Arial Black"
                    FontSize="20"/>
            </Grid>
            <StackPanel Grid.Row="1" Width="300" Margin="0,50,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="35" Height="35" Background="{DynamicResource OrangeBrush}" CornerRadius="2,0,0,2">
                        <Image Source="/Images/user.png" Height="24" Width="24"/>
                    </Border>
                    <TextBox 
                        x:Name="LoginTextBox"
                        Text="admin"
                        Grid.Column="1" 
                        Height="35" 
                        VerticalContentAlignment="Center" 
                        Foreground="{DynamicResource ForegroundBrush}" 
                        Background="{DynamicResource BackgroundTextBoxBrush}" 
                        BorderBrush="{DynamicResource OrangeBrush}" 
                        BorderThickness="1"/>
                </Grid>
                <Grid Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="35" Height="35" Background="{DynamicResource OrangeBrush}" CornerRadius="2,0,0,2">
                        <Image Source="/Images/password.png" Height="24" Width="24"/>
                    </Border>
                    <PasswordBox 
                        x:Name="PasswordBox"
                        Password="admin"
                        Grid.Column="1" 
                        Height="35" 
                        VerticalContentAlignment="Center" 
                        Foreground="{DynamicResource ForegroundBrush}" 
                        Background="{DynamicResource BackgroundTextBoxBrush}" 
                        BorderBrush="{DynamicResource OrangeBrush}" 
                        BorderThickness="1"/>
                </Grid>
                <Button Height="35"
                        Width="150"
                        Margin="20"
                        Content="Войти"
                        Click="LoginButton_Click"
                        Style="{StaticResource OutlineActionButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
